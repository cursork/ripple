#!/usr/bin/perl
# ripple — Execute expressions in a Dyalog APL session via the RIDE protocol.
# Connects, executes expressions, disconnects.
# No dependencies beyond core Perl (IO::Socket::INET, JSON::PP).
# Requires Perl 5.32+ (RHEL 9 baseline).
#
# Usage:
#   ripple [-addr host:port] [-e 'expr'] ...
#   ripple -e "⎕←2+2"
#   ripple -e "⎕SE.Link.Create '#' '/app/src'" -e "#.Run 'Multi'"

use v5.32;
use Getopt::Long;
use IO::Socket::INET;
use JSON::PP;
my $json = JSON::PP->new->utf8(0);

my $addr = 'localhost:4502';
my @exprs;

GetOptions(
    'addr=s' => \$addr,
    'e=s'    => \@exprs,
) or die "Usage: ripple [-addr host:port] [-e expr]...";

for my $file (@ARGV) {
    open my $fh, '<', $file or die "Cannot open $file: $!";
    while (<$fh>) {
        s/^\s+//; s/\s+$//;
        push @exprs, $_ if length;
    }
}

if (!@exprs) { die "Usage: ripple [-addr host:port] [-e expr]..." }

my $sock = IO::Socket::INET->new(PeerAddr => $addr, Proto => 'tcp', Timeout => 10)
    // die "Cannot connect to $addr: $!";

# RIDE framing: [4-byte BE length (includes itself)] [payload]
sub ride_send {
    my $payload = ref $_[0] ? $json->encode($_[0]) : $_[0];
    my $data = "RIDE" . $payload;
    print $sock pack('N', length($data) + 4) . $data;
}

sub ride_recv {
    read($sock, my $buf, 4) == 4 or die "Connection closed";
    my $len = unpack('N', $buf);
    die "Invalid length: $len" if $len < 8 || $len > 1e7;
    my $payload = '';
    while (length($payload) < $len - 4) {
        read($sock, my $chunk, $len - 4 - length($payload)) or die "Connection closed";
        $payload .= $chunk;
    }
    $payload =~ s/^RIDE//;
    return $payload;
}

my $had_error = 0;

sub wait_for_prompt {
    while (1) {
        my $msg = ride_recv();
        $had_error = 1 if $msg =~ /"HadError"/;
        if ($msg =~ /"AppendSessionOutput"/) {
            my $type = ($msg =~ /"type"\s*:\s*(\d+)/) ? $1 : 0;
            if ($type != 14 && $msg =~ /"result"\s*:\s*"((?:[^"\\]|\\.)*)"/) {
                (my $text = $1) =~ s/\\(.)/$1 eq 'n' ? "\n" : $1/ge;
                print {$type == 5 ? *STDERR : *STDOUT} $text;
            }
        }
        return if $msg =~ /"SetPromptType"/ && $msg =~ /"type"\s*:\s*([0-9]+)/ && $1 > 0;
    }
}

# RIDE handshake
my $msg = ride_recv();
die "Expected SupportedProtocols=2, got: $msg" unless $msg eq 'SupportedProtocols=2';
ride_send('SupportedProtocols=2');
ride_send('UsingProtocol=2');
$msg = ride_recv();
die "Expected UsingProtocol=2, got: $msg" unless $msg eq 'UsingProtocol=2';
ride_send(['Identify', {apiVersion => 1, identity => 1}]);
ride_send(['Connect', {remoteId => 2}]);
wait_for_prompt();

# Execute
for my $expr (@exprs) {
    ride_send(['Execute', {text => "$expr\n", trace => 0}]);
    wait_for_prompt();
}

close $sock;
exit($had_error ? 1 : 0);
