use v5.32;use Getopt::Long;use IO::Socket::INET;use JSON::PP;my $json = JSON::PP->new->utf8(0);my $a = 'localhost:4502';my @e;GetOptions('addr=s'=>\$a,'e=s' =>\@e,) or die"Usage: ripple [-addr host:port] [-e expr]...";for my $file (@ARGV){open my $fh,'<',$file or die"Cannot open $file: $!";while (<$fh>){s/^\s+//;s/\s+$//;push @e,$_ if length;}}if (!@e){die"Usage: ripple [-addr host:port] [-e expr]..."}my $s = IO::Socket::INET->new(PeerAddr=>$a,Proto=>'tcp',Timeout=>10)//die"Cannot connect to $a: $!";sub rs{my $p = ref $_[0] ? $json->encode($_[0]) : $_[0];my $data = "RIDE".$p;print $s pack('N',length($data) + 4).$data;}sub rr{read($s,my $buf,4) == 4 or die"Connection closed";my $len = unpack('N',$buf);die"Invalid length: $len" if $len < 8||$len > 1e7;my $p = '';while (length($p) < $len - 4){read($s,my $c,$len - 4 - length($p)) or die"Connection closed";$p.= $c;}$p =~ s/^RIDE//;return $p;}my $had_error = 0;sub wfp{while (1){my $msg = rr();$had_error = 1 if $msg =~ /"HadError"/;if ($msg =~ /"AppendSessionOutput"/){my $type = ($msg =~ /"type"\s*:\s*(\d+)/) ? $1 : 0;if ($type != 14 && $msg =~ /"result"\s*:\s*"((?:[^"\\]|\\.)*)"/){(my $text = $1) =~ s/\\(.)/$1 eq 'n' ? "\n" : $1/ge;print{$type == 5 ? *STDERR : *STDOUT}$text;}}return if $msg =~ /"SetPromptType"/ && $msg =~ /"type"\s*:\s*([0-9]+)/ && $1 > 0;}}my $msg = rr();die"Expected SupportedProtocols=2,got: $msg" unless $msg eq 'SupportedProtocols=2';rs('SupportedProtocols=2');rs('UsingProtocol=2');$msg = rr();die"Expected UsingProtocol=2,got: $msg" unless $msg eq 'UsingProtocol=2';rs(['Identify',{apiVersion=>1,identity=>1}]);rs(['Connect',{remoteId=>2}]);wfp();for my $expr (@e){rs(['Execute',{text=>"$expr\n",trace=>0}]);wfp();}close $s;exit($had_error ? 1 : 0);
